# cipheator client configuration (installer defaults)
server_host=127.0.0.1
server_port=7443

# TLS
# Relative paths are resolved relative to this config file.
ca_file=server.crt
client_cert=
client_key=
verify_peer=true

# behavior
default_key_storage=server
# Clipboard limit during secure mode (0 = block all clipboard data)
clipboard_max_bytes=4096
# Decrypt to temp file (auto-clean on terminate)
decrypt_to_temp=false
# Demo mode (UI banner + defaults)
demo_mode=false
